{
  "name": "todo-app",
  "version": "1.0.0",
  "description": "A full-stack todo application with CRUD operations using Next.js and Prisma",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@prisma/client": "5.22.0",
    "prisma": "5.22.0",
    "next-auth": "4.24.10",
    "socket.io-client": "4.7.5",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@types/node": "20.17.9",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@types/uuid": "9.0.8",
    "typescript": "5.7.2",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "tailwindcss": "3.4.15",
    "postcss": "8.4.49",
    "autoprefixer": "10.4.20"
  }
}